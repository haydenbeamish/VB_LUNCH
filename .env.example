# Backend API base URL (leave empty to use built-in proxy to api.laserbeamcapital.com)
VITE_API_URL=

# Optional: override the backend URL the server-side proxy forwards to
DATA_API_URL=https://api.laserbeamcapital.com

# OpenRouter API key for AI banter generation (server-side)
OPENROUTER_API_KEY=

# Brave Web Search API key for event news (server-side)
BRAVE_WEBSEARCH_API=
