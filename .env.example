# Backend API origin prefix (leave empty for same-origin; server.js proxies /api/vb to the backend)
VITE_API_URL=

# API key for backend authentication (optional)
VITE_LASERBEAMNODE_API_KEY=

# OpenRouter API key for AI banter generation (server-side)
OPENROUTER_API_KEY=

# Brave Web Search API key for event news (server-side)
BRAVE_WEBSEARCH_API=
